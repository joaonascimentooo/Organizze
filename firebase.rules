rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/months/{monthId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/productImages/{imageId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.data.keys().hasOnly(['dataUrl', 'createdAt'])
                            && request.resource.data.dataUrl is string
                            && request.resource.data.dataUrl.size() < 600000;
    }
  }
}
